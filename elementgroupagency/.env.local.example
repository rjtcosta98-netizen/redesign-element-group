# Supabase — formulário de contacto (grava na tabela public.leads)
# Copia este ficheiro para .env.local e preenche com o TEU projeto Supabase.
# A anon/publishable key é segura para usar aqui (só tem permissão de INSERT via RLS).

SUPABASE_URL=https://o-teu-projeto.supabase.co
SUPABASE_ANON_KEY=a-tua-anon-ou-publishable-key

# Cloudflare Turnstile — CAPTCHA invisível nos formulários
# Obtém as chaves em: https://dash.cloudflare.com → Turnstile → Add Site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=a-tua-site-key-publica
TURNSTILE_SECRET_KEY=a-tua-secret-key-privada
