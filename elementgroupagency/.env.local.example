# Resend — envio de emails dos formulários de contacto e subscrição
# Cria conta em resend.com, verifica o domínio elementgroup.pt e copia a API key aqui.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile — CAPTCHA invisível nos formulários (opcional)
# Obtém as chaves em: https://dash.cloudflare.com → Turnstile → Add Site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=a-tua-site-key-publica
TURNSTILE_SECRET_KEY=a-tua-secret-key-privada
