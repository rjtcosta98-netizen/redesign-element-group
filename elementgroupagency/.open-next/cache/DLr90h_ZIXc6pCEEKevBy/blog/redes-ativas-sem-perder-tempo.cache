nt shrink-0\",\"aria-hidden\":true}],\"Planeia o mês de uma vez: um calendário com temas evita o bloqueio do “o que publico hoje?”.\"]}],[\"$\",\"li\",\"1\",{\"className\":\"flex gap-3 text-muted leading-relaxed\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-2 w-1.5 h-1.5 rounded-full bg-accent shrink-0\",\"aria-hidden\":true}],\"Cria em lote: faz vários posts de seguida em vez de um por dia.\"]}],[\"$\",\"li\",\"2\",{\"className\":\"flex gap-3 text-muted leading-relaxed\",\"children\":[[\"$\",\"span\",null,{\"className\":\"mt-2 w-1.5 h-1.5 rounded-full bg-accent shrink-0\",\"aria-hidden\":true}],\"Agenda e esquece: deixa tudo programado e liberta a tua cabeça.\"]}]]}],[\"$\",\"h2\",\"5\",{\"className\":\"text-white font-heading text-xl md:text-2xl font-medium tracking-[-0.01em] mt-10 mb-3\",\"children\":\"Ou então delega\"}],[\"$\",\"p\",\"6\",{\"className\":\"text-muted leading-relaxed my-4\",\"children\":\"Se nem isto te apetece, é exatamente para isso que existe a gestão de redes: tu aprovas, eu trato do resto. As redes ativas, sem te roubarem o dia.\"}]]}]}],[\"$\",\"div\",null,{\"className\":\"px-6 pb-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-[760px] mx-auto rounded-[24px] border border-accent/30 bg-accent/[0.05] p-8 md:p-10 text-center\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-white font-heading text-xl md:text-2xl font-medium tracking-[-0.01em]\",\"children\":\"Gostas do que lês? Posso ajudar-te a aplicá-lo.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-muted text-sm max-w-md mx-auto leading-relaxed\",\"children\":\"Se quiseres pôr isto a funcionar no teu negócio, é só falares comigo — sem compromisso.\"}],[\"$\",\"div\",null,{\"className\":\"mt-7 flex justify-center\",\"children\":[\"$\",\"$L2\",null,{\"href\":\"/servicos/social\",\"className\":\"nova-btn font-body \",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"nova-btn__glow\"}],[\"$\",\"span\",null,{\"aria-hidden\":true,\"classNam