\"https://elementgroup.pt\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Websites \\u0026 Lojas Online\",\"item\":\"https://elementgroup.pt/servicos/web\"}]}</script><section class=\"relative overflow-hidden bg-bg pt-36 pb-24 px-6\"><div aria-hidden=\"true\" class=\"absolute top-10 right-0 w-[640px] h-[640px] pointer-events-none\" style=\"background:radial-gradient(circle at 70% 30%, rgba(127,168,217,0.16), transparent 60%)\"></div><div class=\"relative max-w-[1100px] mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center\"><div class=\"\" style=\"opacity:0;transform:translateX(-30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"text-[11px] uppercase tracking-[0.22em] text-accent/90 mb-5\">Categoria 01 · Websites &amp; Lojas Online</p><h1 class=\"text-white tracking-[-0.03em] leading-[1.04]\">Websites em Portugal que transformam <span class=\"text-accent\">visitantes em clientes</span>.</h1><p class=\"mt-7 text-muted leading-relaxed max-w-xl\">Sites e lojas online à medida para empresas em Portugal que querem ser levadas a sério — ultra-rápidos (PageSpeed 95+), bonitos e pensados para vender. Do design ao alojamento, trato de tudo.</p><div class=\"mt-10 flex flex-col sm:flex-row items-center gap-4\"><a class=\"nova-btn font-body \" href=\"/contacto?servico=Websites%20%26%20Lojas%20Online\"><span aria-hidden=\"true\" class=\"nova-btn__glow\"></span><span aria-hidden=\"true\" class=\"nova-btn__ring\"></span><span aria-hidden=\"true\" class=\"nova-btn__shine\"></span><span class=\"nova-btn__label\">Quero o meu website</span></a><a class=\"group inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white transition-colors\" href=\"/portfolio\">Ver portefólio<span class=\"transition-transform group-hover:translate-x-0.5\" aria-hidden=\"true\">→</span></a></div></div><div class=\"\" style=\"opacity:0;transform:translateX(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><div class=\"relative rounded-[28px] border border-white/10 bg-gradient-to-br from-[#16191f] via-[#121317] to-[#0d0e11] p-6 md:p-8 min-h-[340px] flex items-center justify-center overflow-hidden\"><div aria-hidden=\"true\" class=\"absolute -top-16 left-1/4 w-72 h-72 pointer-events-none\" style=\"background:radial-gradient(circle at 50% 30%, rgba(127,168,217,0.16), transparent 60%)\"></div><div class=\"relative w-full max-w-sm rounded-xl border border-white/10 bg-[#101216] shadow-[0_24px_50px_rgba(0,0,0,0.5)] overflow-hidden\" aria-hidden=\"true\"><div class=\"flex items-center gap-1.5 px-3 py-2.5 border-b border-white/10 bg-white/[0.03]\"><span class=\"w-2.5 h-2.5 rounded-full bg-[#ff5f57]/80\"></span><span class=\"w-2.5 h-2.5 rounded-full bg-[#febc2e]/80\"></span><span class=\"w-2.5 h-2.5 rounded-full bg-[#28c840]/80\"></span><div class=\"ml-2 flex-1 h-5 rounded-full bg-white/[0.06] flex items-center px-2.5 text-[10px] text-dark\">elementgroup.pt</div></div><div class=\"p-4 space-y-2.5\"><div class=\"h-2.5 w-2/3 rounded bg-white/20\"></div><div class=\"h-2 w-2/5 rounded bg-white/10\"></div><div class=\"mt-3 h-20 rounded-lg border border-accent/25 bg-gradient-to-br from-accent/25 to-[#4f7fb8]/5\"></div><div class=\"flex gap-2 pt-1\"><div class=\"h-10 flex-1 rounded-md bg-white/[0.05]\"></div><div class=\"h-10 flex-1 rounded-md bg-white/[0.05]\"></div><div class=\"h-10 flex-1 rounded-md bg-white/[0.05]\"></div></div></div></div><div class=\"absolute bottom-6 right-6 rounded-xl border border-white/10 bg-bg-card/90 backdrop-blur p-3 shadow-[0_16px_36px_rgba(0,0,0,0.5)]\"><p class=\"text-[10px] text-muted\">PageSpeed</p><div class=\"flex items-end gap-1.5\"><span class=\"text-3xl font-heading font-medium text-white leading-none\">98</span><span class=\"text-[10px] text-accent mb-0.5\">/ 100</span></div></div></div></div></div></section><section class=\"relative overflow-hidden bg-bg border-t border-white/10 py-24 px-6\" aria-labelledby=\"problema\"><div aria-hidden=\"true\" class=\"glow-drift absolute -right-24 top-10 w-[520px] h-[520px] pointer-events-none\" style=\"background:radial-gradient(circle at 60% 40%, rgba(216,85,74,0.10), transparent 65%)\"></div><div class=\"relative max-w-[1100px] mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-start\"><div class=\"\" style=\"opacity:0;transform:translateX(-30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-dark mb-5\"><span aria-hidden=\"true\" class=\"relative grid place-items-center w-2 h-2\"><span class=\"absolute inset-0 rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"w-2 h-2 rounded-full bg-[#d8554a]/80\"></span></span>Soa-te familiar?</p><h2 id=\"problema\" class=\"text-white\">O teu site pode estar a <span class=\"pain-word\">afastar clientes</span> — sem dares por isso.</h2><p class=\"mt-6 text-muted leading-relaxed max-w-md\">A maioria das empresas não perde clientes por falta de qualidade, mas porque online não mostra o valor que tem. Reconheces-te nalgum destes?</p></div><ul class=\"flex flex-col gap-3.5\"><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Tens um negócio de confiança, mas o site não passa essa imagem — ou nem tens site.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Quem te procura escolhe quem parece mais profissional.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">É lento ou parece mal no telemóvel, e as pessoas saem antes de ver o que ofereces.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Cada segundo a carregar é um cliente que desiste.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Quando procuram o teu serviço no Google, aparecem os concorrentes — não tu.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>O cliente já era teu — e foi parar à concorrência.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Já pediste orçamento a uma agência e o preço (e a distância) assustaram-te.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>E o site que te traz clientes continua por fazer.</span></p></div></li></ul></div></section><section class=\"bg-bg border-t border-white/10 py-24\" aria-labelledby=\"inclui\"><div class=\"hidden lg:block\"><div style=\"height:294vh\" class=\"relative\"><div class=\"sticky top-0 h-screen flex flex-col justify-center overflow-hidden\"><div class=\"text-center max-w-[640px] mx-auto px-6 mb-8 xl:mb-12\"><