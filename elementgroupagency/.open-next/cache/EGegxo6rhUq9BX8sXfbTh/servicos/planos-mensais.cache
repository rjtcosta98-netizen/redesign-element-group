ness\"},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"Portugal\"},{\"@type\":\"City\",\"name\":\"Seia\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Guarda\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Serra da Estrela\"}],\"inLanguage\":\"pt-PT\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Início\",\"item\":\"https://elementgroup.pt\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Planos Mensais\",\"item\":\"https://elementgroup.pt/servicos/planos-mensais\"}]}</script><section class=\"relative overflow-hidden bg-bg pt-36 pb-24 px-6\"><div aria-hidden=\"true\" class=\"absolute top-10 right-0 w-[640px] h-[640px] pointer-events-none\" style=\"background:radial-gradient(circle at 70% 30%, rgb(var(--accent-rgb) / 0.16), transparent 60%)\"></div><div class=\"relative max-w-[1100px] mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center\"><div class=\"\" style=\"opacity:0;transform:translateX(-30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"text-[11px] uppercase tracking-[0.22em] text-accent/90 mb-5\">Categoria 04 · Planos Mensais</p><h1 class=\"text-white tracking-[-0.03em] leading-[1.04]\">Manutenção de sites e marketing digital, <span class=\"text-accent\">mês após mês</span>.</h1><p class=\"mt-7 text-muted leading-relaxed max-w-xl\">Planos mensais de manutenção, SEO e conteúdo para PMEs que não querem um site parado no tempo — querem um parceiro digital sempre a trabalhar por elas. Site protegido, presença a crescer, zero preocupações técnicas.</p><div class=\"mt-10 flex flex-col sm:flex-row items-center gap-4\"><a class=\"nova-btn font-body \" href=\"/contacto?servico=Planos%20Mensais\"><span aria-hidden=\"true\" class=\"nova-btn__glow\"></span><span aria-hidden=\"true\" class=\"nova-btn__ring\"></span><span aria-hidden=\"true\" class=\"nova-btn__shine\"></span><span class=\"nova-btn__label\">Quero um parceiro contínuo</span></a><a class=\"group inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white transition-colors\" href=\"#preco\">Ver planos<span class=\"transition-transform group-hover:translate-x-0.5\" aria-hidden=\"true\">→</span></a></div></div><div class=\"\" style=\"opacity:0;transform:translateX(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><div class=\"relative rounded-[28px] border border-white/10 bg-gradient-to-br from-[#16191f] via-[#121317] to-[#0d0e11] p-6 md:p-8 min-h-[340px] flex items-center justify-center overflow-hidden\"><div aria-hidden=\"true\" class=\"absolute -top-16 left-1/4 w-72 h-72 pointer-events-none\" style=\"background:radial-gradient(circle at 50% 30%, rgb(var(--accent-rgb) / 0.16), transparent 60%)\"></div><div class=\"relative w-full max-w-sm rounded-xl border border-white/10 bg-[#101216] p-5 shadow-[0_24px_50px_rgba(0,0,0,0.5)]\" aria-hidden=\"true\"><div class=\"flex items-center justify-between mb-4\"><p class=\"text-sm text-white font-medium\">Plano mensal</p><span class=\"inline-flex items-center gap-1.5 rounded-full border border-accent/30 bg-accent/10 px-2.5 py-1 text-[10px] text-accent font-medium\"><svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M21 12a9 9 0 1 1-2.6-6.3M21 4v4h-4\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>Recorrente</span></div><ul class=\"space-y-2.5\"><li class=\"flex items-center gap-2.5\"><span class=\"w-5 h-5 shrink-0 rounded-full bg-gradient-to-br from-accent to-[var(--accent-mid)] flex items-center justify-center text-black text-[11px]\">✓</span><span class=\"text-[12px] text-muted\">Manutenção &amp; backups</span></li><li class=\"flex items-center gap-2.5\"><span class=\"w-5 h-5 shrink-0 rounded-full bg-gradient-to-br from-accent to-[var(--accent-mid)] flex items-center justify-center text-black text-[11px]\">✓</span><span class=\"text-[12px] text-muted\">SEO técnico mensal</span></li><li class=\"flex items-center gap-2.5\"><span class=\"w-5 h-5 shrink-0 rounded-full bg-gradient-to-br from-accent to-[var(--accent-mid)] flex items-center justify-center text-black text-[11px]\">✓</span><span class=\"text-[12px] text-muted\">Conteúdo &amp; posts</span></li><li class=\"flex items-center gap-2.5\"><span class=\"w-5 h-5 shrink-0 rounded-full bg-gradient-to-br from-accent to-[var(--accent-mid)] flex items-center justify-center text-black text-[11px]\">✓</span><span class=\"text-[12px] text-muted\">Relatório de resultados</span></li></ul></div></div></div></div></section><section class=\"relative overflow-hidden bg-bg border-t border-white/10 py-24 px-6\" aria-labelledby=\"problema\"><div aria-hidden=\"true\" class=\"glow-drift absolute -right-24 top-10 w-[520px] h-[520px] pointer-events-none\" style=\"background:radial-gradient(circle at 60% 40%, rgba(216,85,74,0.10), transparent 65%)\"></div><div class=\"relative max-w-[1100px] mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-start\"><div class=\"\" style=\"opacity:0;transform:translateX(-30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-dark mb-5\"><span aria-hidden=\"true\" class=\"relative grid place-items-center w-2 h-2\"><span class=\"absolute inset-0 rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"w-2 h-2 rounded-full bg-[#d8554a]/80\"></span></span>Soa-te familiar?</p><h2 id=\"problema\" class=\"text-white\">Um site não é <span class=\"pain-word\">“feito e esquecido”</span>.</h2><p class=\"mt-6 text-muted leading-relaxed max-w-md\">Um site precisa de cuidado contínuo — segurança, atualizações e presença no Google. Deixado por sua conta, envelhece, abranda e cai nas pesquisas.</p></div><ul class=\"flex flex-col gap-3.5\"><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Lançaste o site há meses e desde aí… nada. Está a ficar desatualizado e a cair no Google.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>O que custou a subir cai sozinho.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Tens receio que algo parta (ou seja pirateado) e não saberes a quem ligar.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>E descobres só quando já estás offline.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Sabes que devias fazer SEO e conteúdo todos os meses, mas não tens tempo nem equipa.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Enquanto paras, a concorrência continua.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Cada pequena alteração vira uma novela — ninguém responde, ninguém resolve.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>E desistes de pedir — o site fica congelado no tempo.</span></p></div></li></ul></div></section><section class=\"bg-bg border-t border-white/10 py-24\" aria-labelledby=\"inclui\"><div class=\"hidden lg:block\"><div style=\"height:294vh\" class=\"relative\"><div class=\"sticky top-0 h-screen flex flex-col justify-center overflow-hidden\"><div class=\"text-center max-w-[640px] mx-auto px-6 mb-8 xl:mb-12\"><p class=\"text-[11px] uppercase tracking-[0.22em] text-dark mb-4\">O que está incluído</p><h2 id=\"inclui\" class=\"text-white\">Manutenção de sites, SEO e conteúdo — todos os meses</h2><p class=\"mt-5 text-muted leading-relaxed\">Manutenção, crescimento e tranquilidade num só plano. Tu tocas no teu negócio; eu trato do digital.</p></div><div class=\"max-w-[1080px] mx-auto w-full px-6 grid grid-cols-2 gap-12 items-center\"><div class=\"flex justify-center\"><div class=\"globe-scene relative\" style=\"width:400px;height:400px\" aria-hidden=\"true\"><div class=\"absolute inset-[-14%] rounded-full\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.18), transparent 65%);filter:blur(10px)\"></div><div class=\"absolute inset-0 globe-3d\" style=\"transform-style:preserve-3d;transform:none\"><div class=\"globe-ring\" style=\"transform:rotateY(0deg)\"></div><div class=\"globe-ring\" style=\"transform:rotateY(30deg)\"></div><div class=\"globe-ring\" style=\"transform:rotateY(60deg)\"></div><div class=\"globe-ring\" style=\"transform:rotateY(90deg)\"></div><div class=\"globe-ring\" style=\"transform:rotateY(120deg)\"></div><div class=\"globe-ring\" style=\"transform:rotateY(150deg)\"></div><div class=\"globe-ring\" sty