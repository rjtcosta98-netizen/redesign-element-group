ect\",null,\"$1b\"]\n1d:{\"d\":\"m10 9 5 3-5 3V9Z\"}\n1c:[\"$\",\"path\",null,\"$1d\"]\n19:[\"$1a\",\"$1c\"]\n18:\"$19\"\n17:{\"title\":\"Vídeo vertical\",\"desc\":\"Reels, TikToks e Shorts com legendas, hook e CTA — o formato que mais alcança hoje.\",\"icon\":\"$18\"}\n22:{\"x\":\"3\",\"y\":\"4\",\"width\":\"18\",\"height\":\"18\",\"rx\":\"2\"}\n21:[\"$\",\"rect\",null,\"$22\"]\n24:{\"d\":\"M16 2v4M8 2v4M3 10h18\"}\n23:[\"$\",\"path\",null,\"$24\"]\n20:[\"$21\",\"$23\"]\n1f:\"$20\"\n1e:{\"title\":\"Calendário de conteúdo\",\"desc\":\"Um plano mensal claro: sabes o que sai e quando. Nada de improviso.\",\"icon\":\"$1f\"}\n28:{\"d\":\"M4 4h16v12H7l-3 3V4Z\"}\n27:[\"$\",\"path\",null,\"$28\"]\n26:\"$27\"\n25:{\"title\":\"Copy que gera ação\",\"desc\":\"Legendas pensadas para interação e para levar à ação — não só para somar likes.\",\"icon\":\"$26\"}\n2d:{\"cx\":\"12\",\"cy\":\"12\",\"r\":\"9\"}\n2c:[\"$\",\"circle\",null,\"$2d\"]\n2f:{\"d\":\"M12 7v5l3 2\"}\n2e:[\"$\",\"path\",null,\"$2f\"]\n2b:[\"$2c\",\"$2e\"]\n2a:\"$2b\"\n29:{\"title\":\"Sem te roubar tempo\",\"desc\":\"Tu aprovas, eu trato do resto. As redes ativas sem ocupar a tua agenda.\",\"icon\":\"$2a\"}\n9:[\"$a\",\"$e\",\"$17\",\"$1e\",\"$25\",\"$29\"]\n30:T60d,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Em que redes trabalham?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Instagram, Facebook e TikTok — conforme onde estão os teus clientes. Foco onde faz sentido para o teu negócio, em vez de estar em todas ao mesmo tempo.\"}},{\"@type\":\"Question\",\"name\":\"Tenho de aparecer ou gravar vídeos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Não é obrigatório. Trabalho com o que tiveres (fotos, vídeos do dia a dia) e crio conteúdo à volta disso. Para Reels, oriento-te se quiseres gravar tu mesmo.\"}},{\"@type\":\"Question\",\"name\":\"Quantos posts por mês?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Depende do plano — definimos um volume controlado à cabeça, para garantir qualidade e não saturar nem o teu feed nem o teu tempo.\"}},{\"@type\":\"Question\",\"name\":\"As redes vão fazer o meu negócio explodir?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sinceramente, não sozinhas. As redes são um complemento — o motor do crescimento é o teu site e o SEO. O que fazem é manter-te presente, credível e na memória de quem te segue.\"}},{\"@type\":\"Question\",\"name\":\"Posso pedir só um pack pontual?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Tens o Pack de Posts (avulso) e o Pack Vídeo Vertical (pagamento único), sem teres de assinar uma avença mensal.\"}},{\"@type\":\"Question\",\"name\":\"Como começo?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pedes um orçamento no formulário (2 minutos). Respondo em menos de 2 horas, sem compromisso.\"}}]}34:T62c,{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://elementgroup.pt/#business\",\"name\":\"Element Group\",\"legalName\":\"Ricardo Jorge Teixeira da Costa\",\"url\":\"https://elementgroup.pt\",\"logo\":\"https://elementgroup.pt/web-app-manifest-512x512.png\",\"image\":\"https://elementgroup.pt/opengraph-image\",\"email\":\"info@elementgroup.pt\",\"telephone\":\"+351 930 477 894\",\"vatID\":\"232177775\",\"priceRange\":\"€€\",\"description\":\"Agência de marketing digital para PMEs em Portugal: criação de websites e lojas online, SEO, gestão de redes sociais e planos mensais.\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rua Principal 9\",\"postalCode\":\"6270-031\",\"addressLocality\":\"Seia\",\"addressRegion\":\"Guarda\",\"addressCountry\":\"PT\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":40.4156,\"longitude\":-7.7081},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"Portugal\"},{\"@type\":\"City\",\"name\":\"Seia\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Guarda\"},{\"@type\":\"AdministrativeArea\",\