ranslateY(26px) scale(0.98)\"><div class=\"relative overflow-hidden rounded-[24px] border border-white/10 p-8 bg-gradient-to-br from-[#181c24] via-[#121419] to-[#0c0d11] shadow-[0_40px_90px_-45px_rgba(0,0,0,0.95),inset_0_1px_0_rgb(255_255_255/0.07)]\"><span aria-hidden=\"true\" class=\"absolute inset-x-0 top-0 h-px\" style=\"background:linear-gradient(90deg, transparent, rgb(var(--accent-rgb) / 0.55), transparent)\"></span><div aria-hidden=\"true\" class=\"absolute -top-20 -right-14 w-60 h-60 pointer-events-none\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.22), transparent 65%)\"></div><div aria-hidden=\"true\" class=\"absolute -bottom-24 -left-16 w-60 h-60 pointer-events-none\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.10), transparent 65%)\"></div><div class=\"relative\"><span class=\"font-heading text-sm tabular-nums\"><span class=\"text-accent\">0<!-- -->2</span><span class=\"text-dark\"> — 0<!-- -->6</span></span><span class=\"relative grid place-items-center rounded-xl bg-gradient-to-br from-[var(--accent-light)] via-accent to-[var(--accent-mid)] text-black\n                  ring-1 ring-white/25 shadow-[0_10px_26px_-8px_rgb(var(--accent-rgb)/0.85)] w-12 h-12 mt-5\"><span aria-hidden=\"true\" class=\"absolute inset-x-0 top-0 h-1/2 rounded-t-xl bg-gradient-to-b from-white/35 to-transparent\"></span><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"relative\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"></rect><circle cx=\"9\" cy=\"9\" r=\"2\"></circle><path d=\"m21 15-5-5L5 21\"></path></svg></span><h3 class=\"mt-5 text-white font-heading text-2xl font-medium tracking-[-0.01em]\">Conteúdo &amp; design</h3><p class=\"mt-3 text-muted leading-relaxed\">Posts com design profissional e copy que para o scroll — com a tua identidade.</p></div></div></article><article aria-hidden=\"true\" class=\"absolute inset-0 flex flex-col justify-center\" style=\"pointer-events:none;opacity:0;transform:translateY(26px) scale(0.98)\"><div class=\"relative overflow-hidden rounded-[24px] border border-white/10 p-8 bg-gradient-to-br from-[#181c24] via-[#121419] to-[#0c0d11] shadow-[0_40px_90px_-45px_rgba(0,0,0,0.95),inset_0_1px_0_rgb(255_255_255/0.07)]\"><span aria-hidden=\"true\" class=\"absolute inset-x-0 top-0 h-px\" style=\"background:linear-gradient(90deg, transparent, rgb(var(--accent-rgb) / 0.55), transparent)\"></span><div aria-hidden=\"true\" class=\"absolute -top-20 -right-14 w-60 h-60 pointer-events-none\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.22), transparent 65%)\"></div><div aria-hidden=\"true\" class=\"absolute -bottom-24 -left-16 w-60 h-60 pointer-events-none\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.10), transparent 65%)\"></div><div class=\"relative\"><span class=\"font-heading text-sm tabular-nums\"><span class=\"text-accent\">0<!-- -->3</span><span class=\"text-dark\"> — 0<!-- -->6</span></span><span class=\"relative grid place-items-center rounded-xl bg-gradient-to-br from-[var(--accent-light)] via-accent to-[var(--accent-mid)] text-black\n                  ring-1 ring-white/25 shadow-[0_10px_26px_-8px_rgb(var(--accent-rgb)/0.85)] w-12 h-12 mt-5\"><span aria-hidden=\"true\" class=\"absolute inset-x-0 top-0 h-1/2 rounded-t-xl bg-gradient-to-b from-white/35 to-transparent\"></span><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"relative\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"></rect><path d=\"m10 9 5 3-5 3V9Z\"></path></svg></span><h3 class=\"mt-5 text-white font-heading text-2xl font-medium tracking-[-0.01em]\">Vídeo vertical</h3><p class=\"mt-3 text-muted leading-relaxed\">Reels, TikToks e Shorts com legendas, hook e CTA — o formato que mais alcança hoje.</p></div></div></article><article aria-hidden=\"true\" class=\"absolute inset-0 flex flex-col justify-center\" style=\"pointer-events:none;opacity:0;transform:translateY(26px) scale(0.98)\"><div class=\"relative overflow-hidden rounded-[24px] border border-white/10 p-8 bg-gradient-to-br from-[#181c24] via-[#121419] to-[#0c0d11] shadow-[0_40px_90px_-45px_rgba(0,0,0,0.95),inset_0_1px_0_rgb(255_255_255/0.07)]\"><span aria-hidden=\"true\" class=\"absolute inset-x-0 top-0 h-px\" style=\"background:linear-gradient(90deg, transparent, rgb(var(--accent-rgb) / 0.55), transparent)\"></span><div aria-hidden=\"true\" class=\"absolute -top-20 -right-14 w-60 h-60 pointer-events-none\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.22), transparent 65%)\"></div><div aria-hidden=\"true\" class=\"absolute -bottom-24 -left-16 w-60 h-60 pointer-events-none\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.10), transparent 65%)\"></div><div class=\"relative\"><span class=\"font-heading text-sm tabular-nums\"><span class=\"text-accent\">0<!-- -->4</span><span class=\"text-dark\"> — 0<!-- -->6</span></span><span class=\"relative grid place-items-center rounded-xl bg-gradient-to-br from-[var(--accent-light)] via-accent to-[var(--accent-mid)] text-black\n                  ring-1 ring-white/25 shadow-[0_10px_26px_-8px_rgb(var(--accent-rgb)/0.85)] w-12 h-12 mt-5\"><span aria-hidden=\"true\" class=\"absolute inset-x-0 top-0 h-1/2 rounded-t-xl bg-gradient-to-b from-white/35 to-transparent\"></span><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"relative\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"></rect><path d=\"M16 2v4M8 2v4M3 10h18\"></path></svg></span><h3 class=\"mt-5 text-white font-heading text-2xl font-medium tracking-[-0.01em]\">Calendário de conteúdo</h3><p class=\"mt-3 text-muted leading-relax