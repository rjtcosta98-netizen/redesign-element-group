",\\\"r\\\":\\\"9\\\"}\\n31:[\\\"$\\\",\\\"circle\\\",null,\\\"$32\\\"]\\n34:{\\\"d\\\":\\\"M12 7v5l3 2\\\"}\\n33:[\\\"$\\\",\\\"path\\\",null,\\\"$34\\\"]\\n30:[\\\"$31\\\",\\\"$33\\\"]\\n2f:\\\"$30\\\"\\n2e:{\\\"title\\\":\\\"Sem te roubar tempo\\\",\\\"desc\\\":\\\"Tu aprovas, eu trato do resto. As redes ativas sem ocupar a tua agenda.\\\",\\\"icon\\\":\\\"$2f\\\"}\\ne:[\\\"$f\\\",\\\"$13\\\",\\\"$1c\\\",\\\"$23\\\",\\\"$2a\\\",\\\"$2e\\\"]\\n35:T60d,{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"FAQPage\\\",\\\"mainEntity\\\":[{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Em que redes trabalham?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Instagram, Facebook e TikTok — conforme onde estão os teus clientes. Foco onde faz sentido para o teu negócio, em vez de estar em todas ao mesmo tempo.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Tenho de aparecer ou gravar vídeos?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Não é obrigatório. Trabalho com o que tiveres (fotos, vídeos do dia a dia) e crio conteúdo à volta disso. Para Reels, oriento-te se quiseres gravar tu mesmo.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Quantos posts por mês?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Depende do plano — definimos um volume controlado à cabeça, para garantir qualidade e não saturar nem o teu feed nem o teu tempo.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"As redes vão fazer o meu negócio explodir?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sinceramente, não sozinhas. As redes são um complemento — o motor do crescimento é o teu site e o SEO. O que fazem é manter-te presente, credível e na memória de quem te segue.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Posso pedir só um pack pontual?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sim. Tens o Pack de Posts (avulso