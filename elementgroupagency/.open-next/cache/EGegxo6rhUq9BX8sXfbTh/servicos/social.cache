7 1.58 1.58 0 0 0-1.57-1.57Z\"></path></svg></a><a href=\"https://www.facebook.com/elementgroupdigital/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebook\" class=\"grid place-items-center w-9 h-9 rounded-full border border-white/10 text-muted hover:text-white hover:border-accent/50 transition-colors\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z\"></path></svg></a><a href=\"https://www.tiktok.com/@elementgroup.pt\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"TikTok\" class=\"grid place-items-center w-9 h-9 rounded-full border border-white/10 text-muted hover:text-white hover:border-accent/50 transition-colors\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M16.6 5.82a4.78 4.78 0 0 1-1.04-.65 4.7 4.7 0 0 1-1.7-3.17h-3.02v12.97a2.66 2.66 0 0 1-2.66 2.55 2.66 2.66 0 0 1-1.2-5.03 2.66 2.66 0 0 1 1.95-.18v-3.05a5.71 5.71 0 0 0-4.9 1.55 5.71 5.71 0 0 0 3.96 9.78 5.71 5.71 0 0 0 5.86-5.71V8.9a7.68 7.68 0 0 0 4.5 1.44V7.32a4.6 4.6 0 0 1-1.71-.5Z\"></path></svg></a></div></div></div></div></div><main style=\"--accent-rgb:169 138 212;--accent:#A98AD4;--accent-deep:#543f7d;--accent-mid:#7d63ad;--accent-light:#ddccf0\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Gestão de Redes Sociais e Conteúdo\",\"serviceType\":\"Gestão de redes sociais e criação de conteúdo\",\"description\":\"Gestão de redes sociais e criação de conteúdo para PMEs em Portugal: posts com design, copy e vídeos verticais (Reels, TikTok, Shorts).\",\"url\":\"https://elementgroup.pt/servicos/social\",\"provider\":{\"@id\":\"https://elementgroup.pt/#business\"},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"Portugal\"},{\"@type\":\"City\",\"name\":\"Seia\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Guarda\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Serra da Estrela\"}],\"inLanguage\":\"pt-PT\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Início\",\"item\":\"https://elementgroup.pt\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Social Media\",\"item\":\"https://elementgroup.pt/servicos/social\"}]}</script><section class=\"relative overflow-hidden bg-bg pt-36 pb-24 px-6\"><div aria-hidden=\"true\" class=\"absolute top-10 right-0 w-[640px] h-[640px] pointer-events-none\" style=\"background:radial-gradient(circle at 70% 30%, rgb(var(--accent-rgb) / 0.16), transparent 60%)\"></div><div class=\"relative max-w-[1100px] mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center\"><div class=\"\" style=\"opacity:0;transform:translateX(-30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"text-[11px] uppercase tracking-[0.22em] text-accent/90 mb-5\">Categoria 03 · Social Media &amp; Conteúdo</p><h1 class=\"text-white tracking-[-0.03em] leading-[1.04]\">Gestão de redes sociais que <span class=\"text-accent\">te poupa tempo</span>.</h1><p class=\"mt-7 text-muted leading-relaxed max-w-xl\">Gestão de redes e conteúdo para PMEs em Portugal que querem estar presentes e profissionais — sem passar o dia a criar posts. Um complemento ao que faz o teu negócio crescer.</p><div class=\"mt-10 flex flex-col sm:flex-row items-center gap-4\"><a class=\"nova-btn font-body \" href=\"/contacto?servico=Social%20Media\"><span aria-hidden=\"true\" class=\"nova-btn__glow\"></span><span aria-hidden=\"true\" class=\"nova-btn__ring\"></span><span aria-hidden=\"true\" class=\"nova-btn__shine\"></span><span class=\"nova-btn__label\">Quero as minhas redes ativas</span></a><a class=\"group inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white transition-colors\" href=\"/portfolio\">Ver portefólio<span class=\"transition-transform group-hover:translate-x-0.5\" aria-hidden=\"true\">→</span></a></div></div><div class=\"\" style=\"opacity:0;transform:translateX(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><div class=\"relative rounded-[28px] border border-white/10 bg-gradient-to-br from-[#16191f] via-[#121317] to-[#0d0e11] p-6 md:p-8 min-h-[340px] flex items-center justify-center overflow-hidden\"><div aria-hidden=\"true\" class=\"absolute -top-16 left-1/4 w-72 h-72 pointer-events-none\" style=\"background:radial-gradient(circle at 50% 30%, rgb(var(--accent-rgb) / 0.16), transparent 60%)\"></div><div class=\"relative w-full max-w-[260px] rounded-xl border border-white/10 bg-[#101216] shadow-[0_24px_50px_rgba(0,0,0,0.5)] overflow-hidden\" aria-hidden=\"true\"><div class=\"flex items-center gap-2 p-3\"><span class=\"w-7 h-7 rounded-full bg-gradient-to-br from-accent to-[var(--accent-mid)]\"></span><div class=\"flex-1\"><div class=\"h-2 w-20 rounded bg-white/25 mb-1\"></div><div class=\"h-1.5 w-12 rounded bg-white/10\"></div></div><span class=\"text-dark text-lg leading-none\">···</span></div><div class=\"h-32 bg-gradient-to-br from-accent/25 via-[var(--accent-mid)]/10 to-transparent border-y border-white/5\"></div><div class=\"flex items-center gap-4 p-3 text-white/70\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linejoin=\"round\"></path></svg><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M21 11.5a8 8 0 0 1-11.5 7.2L4 20l1.3-5.4A8 8 0 1 1 21 11.5Z\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linejoin=\"round\"></path></svg><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 12l16-7-7 16-2.2-6.8L4 12Z\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linejoin=\"round\"></path></svg></div></div><div class=\"absolute bottom-6 right-6 rounded-xl border border-white/10 bg-bg-card/90 backdrop-blur p-3 shadow-[0_16px_36px_rgba(0,0,0,0.5)]\"><p class=\"text-[10px] text-muted mb-1.5\">Alcance</p><div class=\"flex items-end gap-1 h-9\"><span class=\"w-1.5 rounded-sm bg-gradient-to-t from-accent/40 to-accent\" style=\"height:35%\"></span><span class=\"w-1.5 rounded-sm bg-gradient-to-t from-accent/40 to-accent\" style=\"height:50%\"></span><span class=\"w-1.5 rounded-sm bg-gradient-to-t from-accent/40 to-accent\" style=\"height:42%\"></span><span class=\"w-1.5 rounded-sm bg-gradient-to-t from-accent/40 to-accent\" style=\"height:68%\"></span><span class=\"w-1.5 rounded-sm bg-gradient-to-t from-accent/40 to-accent\" style=\"height:84%\"></span><span class=\"w-1.5 rounded-sm bg-gradient-to-t from-accent/40 to-accent\" style=\"height:100%\"></span></div></div></div></div></div></section><section class=\"relative overflow-hidden bg-bg border-t border-white/10 py-24 px-6\" aria-labelledby=\"problema\"><div aria-hidden=\"true\" class=\"glow-drift absolute -right-24 top-10 w-[520px] h-[520px] pointer-events-none\" style=\"background:radial-gradient(circle at 60% 40%, rgba(216,85,74,0.10), transparent 65%)\"></div><div class=\"relative max-w-[1100px] mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-start\"><div class=\"\" style=\"opacity:0;transform:translateX(-30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-dark mb-5\"><span aria-hidden=\"true\" class=\"relative grid place-items-center w-2 h-2\"><span class=\"absolute inset-0 rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"w-2 h-2 rounded-full bg-[#d8554a]/80\"></span></span>Soa-te familiar?</p><h2 id=\"problema\" class=\"text-white\">Redes paradas passam a <span class=\"pain-word\">imagem errada</span>.</h2><p class=\"mt-6 text-muted leading-relaxed max-w-md\">Hoje, quando alguém te conhece, vai espreitar as tuas redes. O que encontra lá fala por ti — para o bem ou para o mal.</p></div><ul class=\"flex flex-col gap-3.5\"><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Há semanas (ou meses) sem publicar — e quem te procura pensa que já fechaste.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Perfil parado lê-se como negócio parado.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Sabes que devias publicar, mas nunca tens tempo nem vontade.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>E adiar vira meses sem presença nenhuma.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Os posts que fazes não têm linha nem design — parecem amadores ao lado da concorrência.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Pareces menor do que realmente és.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Tentaste Reels, mas editar vídeo leva horas e acabas por desistir.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>E é o formato que mais alcança hoje a passar-te ao lado.</span></p></div></li></ul></div></section><section class=\"bg-bg border-t border-white/10 py-24\" aria-labelledby=\"inclui\"><div class=\"hidden lg:block\"><div style=\"height:294vh\" class=\"relative\"><div class=\"sticky top-0 h-screen flex flex-col justify-center overflow-hidden\"><div class=\"text-center max-w-[640px] mx-auto px-6 mb-8 xl:mb-12\"><p class=\"text-[11px] uppercase tracking-[0.22em] text-dark mb-4\">O que está incluído</p><h2 id=\"inclui\" class=\"text-white\">Gestão de redes sociais e conteúdo, do plano à publicação</h2><p class=\"mt-5 text-muted leading-relaxed\">Tu aprovas, eu trato do resto. Presença consistente, com a tua identidade — sem te ocupar a agenda.</p></div><div class=\"max-w-[1080px] mx-auto w-full px-6 grid grid-cols-2 gap-12 items-center\"><div class=\"flex justify-center\"><div class=\"globe-scene relative\" style=\"width:400px;height:400px\" aria-hidden=\"true\"><div class=\"absolute inset-[-14%] rounded-full\" style=\"background:radial-gradient(circle, rgb(var(--accent-rgb) / 0.18), transparent 65%);filter:blur(10px)\"></div><div class=\"absolute inset-0 globe-3d\" style=\"transform-style:preserve-3d;transform:none\"><div class=\"globe-ring\" style=\"transform:rotateY(0deg)\"></div><div class=\"globe-ring\" style=\"transform:rotateY(30deg)\"></div><div class=\"globe-ring\"