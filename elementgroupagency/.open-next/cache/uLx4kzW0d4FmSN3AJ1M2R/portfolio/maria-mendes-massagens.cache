 rgb(var(--accent-rgb) / 0.16), transparent 60%)\"></div><span aria-hidden=\"true\" class=\"absolute top-3 left-3 w-4 h-4 border-l border-t border-white/25\"></span><span aria-hidden=\"true\" class=\"absolute top-3 right-3 w-4 h-4 border-r border-t border-white/25\"></span><span aria-hidden=\"true\" class=\"absolute bottom-3 left-3 w-4 h-4 border-l border-b border-white/25\"></span><span aria-hidden=\"true\" class=\"absolute bottom-3 right-3 w-4 h-4 border-r border-b border-white/25\"></span><span aria-hidden=\"true\" class=\"absolute left-3 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-accent shadow-[0_0_10px_rgb(var(--accent-rgb)/0.9)]\"></span><dl class=\"relative grid grid-cols-2 lg:grid-cols-4 lg:divide-x divide-white/10 p-3 sm:p-5\"><div class=\"px-4 sm:px-7 py-6\"><dt class=\"text-xs uppercase tracking-[0.18em] text-dark mb-2\">Cliente</dt><dd class=\"text-sm text-white/90 leading-snug\">Maria Mendes Massagens</dd></div><div class=\"px-4 sm:px-7 py-6\"><dt class=\"text-xs uppercase tracking-[0.18em] text-dark mb-2\">Setor</dt><dd class=\"text-sm text-white/90 leading-snug\">Massagens &amp; bem-estar · Serviço local</dd></div><div class=\"px-4 sm:px-7 py-6\"><dt class=\"text-xs uppercase tracking-[0.18em] text-dark mb-2\">Serviços</dt><dd class=\"text-sm text-white/90 leading-snug\">SEO local &amp; otimização Google · Criação de Websites &amp; Landing Pages</dd></div><div class=\"px-4 sm:px-7 py-6\"><dt class=\"text-xs uppercase tracking-[0.18em] text-dark mb-2\">Ano</dt><dd class=\"text-sm text-white/90 leading-snug\">2026</dd></div></dl></div></section><section class=\"relative overflow-hidden bg-bg border-t border-white/10 py-24 px-6\" aria-labelledby=\"problema\"><div aria-hidden=\"true\" class=\"glow-drift absolute -right-24 top-10 w-[520px] h-[520px] pointer-events-none\" style=\"background:radial-gradient(circle at 60% 40%, rgba(216,85,74,0.10), transparent 65%)\"></div><div class=\"relative max-w-[1100px] mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-start\"><div class=\"\" style=\"opacity:0;transform:translateX(-30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-dark mb-5\"><span aria-hidden=\"true\" class=\"relative grid place-items-center w-2 h-2\"><span class=\"absolute inset-0 rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"w-2 h-2 rounded-full bg-[#d8554a]/80\"></span></span>O ponto de partida</p><h2 id=\"problema\" class=\"text-white\">Um serviço de excelência — que ninguém encontrava no Google.</h2><p class=\"mt-6 text-muted leading-relaxed max-w-md\">Quem oferece um serviço local vive de aparecer no Google quando procuram perto. A Maria Mendes não tinha site nem ficha de negócio — era invisível. Cada pesquisa de «massagens em Seia» terminava na concorrência, mesmo com um serviço de excelência.</p></div><ul class=\"flex flex-col gap-3.5\"><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Sem site e sem ficha no Google, era praticamente invisível para quem procurava massagens na zona.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Cada pesquisa local terminava na concorrência.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Todo o negócio dependia do passa-palavra e das redes sociais.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Sem pesquisa, o crescimento tinha um teto.</span></p></div></li><li class=\"group relative flex items-start gap-4 overflow-hidden rounded-2xl border border-white/10 bg-bg-card/50 p-4 pl-5 transition-colors duration-300 hover:border-[#d8554a]/45 hover:bg-[#d8554a]/[0.04]\" style=\"opacity:0;transform:translateX(24px)\"><span aria-hidden=\"true\" class=\"absolute inset-0 pointer-events-none bg-[#d8554a]\" style=\"opacity:0\"></span><span aria-hidden=\"true\" class=\"absolute left-0 top-3 bottom-3 w-[3px] rounded-full bg-[#d8554a] pain-bar\"></span><span class=\"relative grid place-items-center w-6 h-6 shrink-0 rounded-full border border-[#d8554a]/30 bg-[#d8554a]/10 text-[#e9a298] mt-0.5\" aria-hidden=\"true\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path><path d=\"M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z\"></path></svg></span><div class=\"relative min-w-0\"><p class=\"text-sm text-white/80 leading-relaxed\">Quem procurava no momento de decidir simplesmente não a encontrava.</p><p class=\"mt-2 flex items-start gap-1.5 text-[13px] text-[#e9a298] leading-snug\"><svg class=\"shrink-0 mt-px\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 7v10h10\"></path><path d=\"m7 17 10-10\"></path></svg><span>Clientes prontos a marcar ficavam por captar.</span></p></div></li></ul></div></section><section class=\"bg-bg border-t border-white/10 py-20 px-6\"><div class=\"max-w-[1000px] mx-auto\"><div class=\"max-w-[640px] mb-12\" style=\"opacity:0;transform:translateY(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"text-xs uppercase tracking-[0.2em] text-accent mb-4\">A abordagem</p><h2 class=\"text-white\">O que fizemos</h2><p class=\"mt-6 text-white/85 leading-relaxed\">Construímos uma landing page rápida e focada em conversão e trabalhámos o SEO local de raiz: criámos e otimizámos a ficha Google Business, produzimos conteúdo orientado às pesquisas certas e garantimos um site ultra-rápido (PageSpeed 95+). O resultado é a posição de topo para as pesquisas que realmente trazem clientes. Online em abril de 2026.</p></div><div class=\"grid sm:grid-cols-2 md:grid-cols-3 gap-5\"><div class=\"\" style=\"opacity:0;transform:translateY(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><div class=\"glow-card h-full\"><span aria-hidden=\"true\" class=\"glow-card__wave\"></span><span aria-hidden=\"true\" class=\"glow-card__ring\"></span><div class=\"glow-card__content h-full p-6\"><span class=\"font-heading text-sm tabular-nums text-accent\">0<!-- -->1</span><h3 class=\"mt-3 text-white font-heading text-lg font-medium tracking-[-0.01em]\">Landing page de conversão</h3><p class=\"mt-2.5 text-muted text-sm leading-relaxed\">Uma página rápida e clara, pensada para transformar quem chega em marcação — serviços, confiança e contacto à mão. Resolveu a ausência total de presença online.</p></div></div></div><div class=\"\" style=\"opacity:0;transform:translateY(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0.08s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0.08s;will-change:opacity, transform\"><div class=\"glow-card h-full\"><span aria-hidden=\"true\" class=\"glow-card__wave\"></span><span aria-hidden=\"true\" class=\"glow-card__ring\"></span><div class=\"glow-card__content h-full p-6\"><span class=\"font-heading text-sm tabular-nums text-accent\">0<!-- -->2</span><h3 class=\"mt-3 text-white font-heading text-lg font-medium tracking-[-0.01em]\">Ficha Google Business de raiz</h3><p class=\"mt-2.5 text-muted text-sm leading-relaxed\">Criámos e otimizámos a ficha de negócio — para aparecer no Google Maps e nas pesquisas locais, exatamente onde os clientes procuram.</p></div></div></div><div class=\"\" style=\"opacity:0;transform:translateY(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0.16s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0.16s;will-change:opacity, transform\"><div class=\"glow-card h-full\"><span aria-hidden=\"true\" class=\"glow-card__wave\"></span><span aria-hidden=\"true\" class=\"glow-card__ring\"></span><div class=\"glow-card__content h-full p-6\"><span class=\"font-heading text-sm tabular-nums text-accent\">0<!-- -->3</span><h3 class=\"mt-3 text-white font-heading text-lg font-medium tracking-[-0.01em]\">SEO local &amp; conteúdo certo</h3><p class=\"mt-2.5 text-muted text-sm leading-relaxed\">Conteúdo orientado às pesquisas reais da zona («massagens são romão», «massagens seia») — para chegar ao topo de quem decide perto.</p></div></div></div></div><div class=\"mt-9\" style=\"opacity:0;transform:translateY(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"text-xs uppercase tracking-[0.2em] text-dark mb-4\">Entregue neste projeto</p><ul class=\"grid grid-cols-2 sm:grid-cols-3 gap-2.5 sm:gap-3\"><li class=\"flex items-center gap-2 rounded-2xl border border-white/10 bg-bg-card px-4 py-3 text-[13px] text-white/80\"><span class=\"text-accent shrink-0\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"></path></svg></span><span class=\"leading-snug\">Landing page à medida</span></li><li class=\"flex items-center gap-2 rounded-2xl border border-white/10 bg-bg-card px-4 py-3 text-[13px] text-white/80\"><span class=\"text-accent shrink-0\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"></path></svg></span><span class=\"leading-snug\">SEO local</span></li><li class=\"flex items-center gap-2 rounded-2xl border border-white/10 bg-bg-card px-4 py-3 text-[13px] text-white/80\"><span class=\"text-accent shrink-0\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"></path></svg></span><span class=\"leading-snug\">Ficha Google Business</span></li><li class=\"flex items-center gap-2 rounded-2xl border border-white/10 bg-bg-card px-4 py-3 text-[13px] text-white/80\"><span class=\"text-accent shrink-0\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"></path></svg></span><span class=\"leading-snug\">Conteúdo otimizado para pesquisa</span></li><li class=\"flex items-center gap-2 rounded-2xl border border-white/10 bg-bg-card px-4 py-3 text-[13px] text-white/80\"><span class=\"text-accent shrink-0\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"></path></svg></span><span class=\"leading-snug\">Site rápido (PageSpeed 95+)</span></li><li class=\"flex items-center gap-2 rounded-2xl border border-white/10 bg-bg-card px-4 py-3 text-[13px] text-white/80\"><span class=\"text-accent shrink-0\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"></path></svg></span><span class=\"leading-snug\">Design 100% responsivo</span></li></ul></div></div></section><section class=\"relative overflow-hidden bg-bg border-t border-white/10 py-20 px-6\"><div class=\"max-w-[1100px] mx-auto\"><div class=\"mb-12\" style=\"opacity:0;transform:translateY(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><p class=\"text-xs uppercase tracking-[0.2em] text-dark mb-3\">Destaques visuais</p><h2 class=\"text-white\">Por dentro do projeto</h2></div><div class=\"mb-14\" style=\"opacity:0;transform:translateY(30px);transition:opacity 0.6s cubic-bezier(0.44,0,0.56,1) 0s, transform 0.6s cubic-bezier(0.44,0,0.56,1) 0s;will-change:opacity, transform\"><div class=\"relative overflow-hidden\"><div aria-hidden=\"true\" class=\"absolute -top-16 left-1/2 -translate-x-1/2 w-[700px] max-w-full h-[440px] pointer-events-none\" style=\"background:radial-gradient(circle at 50% 30%, rgb(var(--accent-rgb) / 0.14), transparent 62%)\"></div><div class=\"relative flex flex-col items-center lg:flex-row lg:items-end lg:justify-center gap-10 lg:gap-0\"><div class=\"w-full lg:max-w-[680px] rounded-[14px] overflow-hidden border border-white/12 bg-[#101216] shadow-[0_44px_100px_-44px_rgba(0,0,0,0.9)]\"><div class=\"flex items-center gap-2 px-4 h-10 border-b border-white/10 bg-white/[0.03]\"><span class=\"w-3 h-3 rounded-full bg-[#ff5f57]/85\"></span><span class=\"w-3 h-3 rounded-full bg-[#febc2e]/85\"></span><span class=\"w-3 h-3 rounded-full bg-[#28c840]/85\"></span><div class=\"ml-3 flex-1 flex items-center justify-center\"><div class=\"flex items-center gap-2 h-6 w-full max-w-[340px] rounded-full bg-white/[0.06] px-3\"><svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" class=\"text-dark shrink-0\" aria-hidden=\"true\"><rect x=\"4\" y=\"11\" width=\"16\" height=\"9\" rx=\"2\"></rect><path d=\"M8 11V7a4 4 0 0 1 8 0v4\"></path></svg><span class=\"text-[11px] text-dark 