to-[#0d0e11] shadow-[0_40px_90px_-40px_rgba(0,0,0,0.7)] grid md:grid-cols-2 items-stretch\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"aria-hidden\\\":true,\\\"className\\\":\\\"absolute -top-24 left-1/4 w-[440px] h-[440px] pointer-events-none\\\",\\\"style\\\":{\\\"background\\\":\\\"radial-gradient(circle at 50% 30%, rgba(127,168,217,0.20), transparent 60%)\\\"}}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative p-8 md:p-12 flex flex-col justify-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center gap-2 self-start rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 mb-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"$Lf\\\",null,{\\\"src\\\":\\\"/web-app-manifest-512x512.png\\\",\\\"alt\\\":\\\"\\\",\\\"width\\\":16,\\\"height\\\":16,\\\"className\\\":\\\"w-4 h-4\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-[11px] uppercase tracking-[0.16em] text-muted\\\",\\\"children\\\":\\\"A minha história\\\"}]]}],[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"historia\\\",\\\"className\\\":\\\"text-white font-heading text-3xl md:text-[34px] font-medium tracking-[-0.02em] leading-tight\\\",\\\"children\\\":\\\"Como (e porquê) começou\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-6 space-y-4 text-muted text-sm leading-relaxed\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Via sempre o mesmo: negócios bons — daqueles de confiança — escondidos atrás de um site fraco, ou sem presença nenhuma online. E as agências que podiam ajudar eram caras e distantes de mais para um pequeno negócio.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Comecei a fazer sites para amigos, quase como quem ajuda ao fim de semana. Mas os resultados apareciam — mais visitas, mais contactos, mais clientes. Aquilo que para mim era natural estava a mudar negócios reais.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Em 2026 deixei de o fazer como favor e passei a fazê-lo