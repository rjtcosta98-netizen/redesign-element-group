2 lg:gap-16 items-center\",\"children\":[[\"$\",\"$Lc\",null,{\"direction\":\"left\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[11px] uppercase tracking-[0.22em] text-dark mb-5\",\"children\":\"O porquê\"}],[\"$\",\"h1\",null,{\"className\":\"text-white tracking-[-0.03em] leading-[1.04]\",\"children\":[\"Nenhum bom negócio devia perder clientes por não ser \",[\"$\",\"span\",null,{\"className\":\"text-accent\",\"children\":\"encontrado online\"}],\".\"]}],[\"$\",\"p\",null,{\"className\":\"mt-7 text-muted leading-relaxed max-w-xl\",\"children\":\"É nisto que acredito desde o primeiro site que fiz para um amigo. As grandes agências são caras e distantes — e as PMEs merecem melhor. Foi por isso que criei a Element Group: dar aos pequenos negócios em Portugal uma presença online de topo, sem o preço nem a distância de uma agência. Trabalho a partir de Seia, na Serra da Estrela (distrito da Guarda), com clientes em todo o país.\"}],[\"$\",\"p\",null,{\"className\":\"mt-8 text-xs text-muted flex flex-wrap items-center gap-x-2.5 gap-y-1\",\"children\":[[\"$\",\"span\",null,{\"children\":\"Desde 2026\"}],[\"$\",\"span\",null,{\"className\":\"text-dark\",\"aria-hidden\":true,\"children\":\"·\"}],[\"$\",\"span\",null,{\"children\":\"Estúdio em Seia, Portugal\"}],[\"$\",\"span\",null,{\"className\":\"text-dark\",\"aria-hidden\":true,\"children\":\"·\"}],[\"$\",\"span\",null,{\"children\":[[\"$\",\"span\",null,{\"className\":\"text-accent\",\"aria-hidden\":true,\"children\":\"★\"}],\" 5,0 no Google\"]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-10 flex flex-col items-start sm:flex-row sm:items-center gap-4\",\"children\":[[\"$\",\"$L7\",null,{\"href\":\"/contacto\",\"className\":\"nova-btn font-body \",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"nova-btn__glow\"}],[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"nova-btn__ring\"}],[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"nova-btn__shine\"}],[\"$\",\"span\",n