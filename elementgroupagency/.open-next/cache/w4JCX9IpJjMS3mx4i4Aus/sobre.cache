3\",\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"children\":[\"$\",\"path\",null,{\"d\":\"M5 12l5 5 9-10\",\"stroke\":\"currentColor\",\"strokeWidth\":\"2.4\",\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\"}]}]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-white font-medium\",\"children\":\"Sem intermediários\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-[11px] text-muted\",\"children\":\"Falas sempre com quem faz o teu projeto.\"}]]}]]}]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"relative overflow-hidden bg-bg py-24 px-6\",\"aria-labelledby\":\"historia\",\"children\":[[\"$\",\"div\",null,{\"aria-hidden\":true,\"className\":\"glow-drift absolute -left-40 top-1/3 -translate-y-1/2 w-[620px] h-[620px] pointer-events-none\",\"style\":{\"background\":\"radial-gradient(circle, rgba(127,168,217,0.11), transparent 60%)\"}}],[\"$\",\"div\",null,{\"className\":\"relative max-w-[1100px] mx-auto\",\"children\":[\"$\",\"$Lc\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"relative overflow-hidden rounded-[32px] border border-white/10 bg-gradient-to-br from-[#16191f] via-[#121317] to-[#0d0e11] shadow-[0_40px_90px_-40px_rgba(0,0,0,0.7)] grid md:grid-cols-2 items-stretch\",\"children\":[[\"$\",\"div\",null,{\"aria-hidden\":true,\"className\":\"absolute -top-24 left-1/4 w-[440px] h-[440px] pointer-events-none\",\"style\":{\"background\":\"radial-gradient(circle at 50% 30%, rgba(127,168,217,0.20), transparent 60%)\"}}],[\"$\",\"div\",null,{\"className\":\"relative p-8 md:p-12 flex flex-col justify-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"inline-flex items-center gap-2 self-start rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 mb-6\",\"children\":[[\"$\",\"$L8\",null,{\"src\":\"/web-app-manifest-512x512.png\",\"alt\":\"\",\"width\":16,\"height\":16,\"className\":\"w-4 h-4\"}],[\"$\",\"span\",null,{\"className\":\"text-[11px] uppercase tracking-[0.16em] text-muted\",\"children\":\"A minha história\"}]]}],[\"$\",\"h2\",null,{\"id\":\"historia\",\"className\":\"text-white font-heading text-3xl md:text-[34px] font-medium tracking-[-0.02em] leading-tight\",\"children\":\"Como (e porquê) começou\"}],[\"$\",\"div\",null,{\"className\":\"mt-6 space-y-4 text-muted text-sm leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Via sempre o mesmo: negócios bons — daqueles de confiança — escondidos atrás de um site fraco, ou sem presença nenhuma online. E as agências que podiam ajudar eram caras e distantes de mais para um pequeno negócio.\"}],[\"$\",\"p\",null,{\"children\":\"Comecei a fazer sites para amigos, quase como quem ajuda ao fim de semana. Mas os resultados apareciam — mais visitas, mais contactos, mais clientes. Aquilo que para mim era natural estava a mudar negócios reais.\"}],[\"$\",\"p\",null,{\"children\":\"Em 2026 deixei de o fazer como favor e passei a fazê-lo a sério. Nasceu a Element Group — para que qualquer PME em Portugal possa ter uma presença online de que se orgulha.\"}]]}],[\"$\",\"blockquote\",null,{\"className\":\"mt-8 border-l-2 border-accent/60 pl-5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-heading text-lg md:text-xl text-white leading-snug tracking-[-0.01em]\",\"children\":\"“Um bom negócio nunca devia parecer pequeno online.”\"}],[\"$\",\"footer\",null,{\"className\":\"mt-2 text-2xl text-white/90\",\"style\":{\"fontFamily\":\"var(--font-signature)\"},\"children\":\"Ricardo Jorge\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"relative min-h-[420px] md:min-h-0\",\"children\":[[\"$\",\"$L8\",null,{\"src\":\"/ricardo-full.jpg\",\"alt\":\"Ricardo Jorge no escritório da Element Group\",\"fill\":true,\"sizes\":\"(max-width: 768px) 100vw, 550px\",\"priority\":true,\"className\":\"object-cover object-center\"}],[\"$\",\"div\",null,{\"aria-hidden\":true,\"className\":\"absolute inset-0 pointer-events-none bg-gradient-to-r from-[#121317] via-[#121317]/30 to-transparent md:via-[#121317]/45\"}],[\"$\",\"div\",null,{\"aria-hidden\":true,\"className